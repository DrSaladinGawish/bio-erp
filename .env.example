# === DATABASE ===
# Docker dev / production (PostgreSQL — recommended):
DATABASE_URL=postgresql+asyncpg://bioerp:bioerp_prod_secret_2026@bioerp_db:5432/bio_erp

# Local dev without Docker (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./bio_erp.db

# === REDIS (for Celery + caching) ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === SECURITY ===
SECRET_KEY=replace-with-64-char-random-string-now
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEBUG=true

# === ETA (Egyptian Tax Authority) ===
ETA_BASE_URL=https://api.preprod.eta.gov.eg
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_PRIVATE_KEY_PATH=./keys/eta_private.pem
ETA_PUBLIC_KEY_PATH=./keys/eta_public.pem

# === COMPANY ===
COMPANY_TAX_ID=123456789
COMPANY_NAME=BIO-ERP Company
COMPANY_ACTIVITY_CODE=6201
DEFAULT_BRANCH_ID=1
DEFAULT_CURRENCY_ID=1
VAT_RATE_EG=0.14
VAT_RATE_UAE=0.05

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@bioerp.local

# === CBE (Central Bank of Egypt) ===
CBE_API_URL=https://www.cbe.org.eg/api/currency-rates
CBE_API_KEY=

# === DOCKER PRODUCTION ===
# DB_PASSWORD=bioerp_prod_secret_2026
# GRAFANA_PASSWORD=admin
